# Meta/Facebook API
META_BUSINESS_ACCOUNT_ID=seu_business_account_id_aqui
META_ACCESS_TOKEN=seu_access_token_aqui
# Conta de anuncio FIXA (recomendado!). Sem ela, a dashboard usa a primeira conta
# que a BM listar — se a BM for compartilhada, pode mostrar anuncios de terceiros.
# Aceita com ou sem o prefixo "act_". Ex.: act_1234567890 ou 1234567890
META_AD_ACCOUNT_ID=sua_conta_de_anuncio_aqui
META_APP_ID=seu_app_id_aqui
META_APP_SECRET=seu_app_secret_aqui

# Vercel / Deployment
VERCEL_ENV=production
